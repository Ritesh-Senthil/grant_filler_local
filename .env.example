# Copy to backend/.env (the API always loads that file by path — you can start uvicorn from any directory).
# Restart the API after changing this file so Settings() reloads.

DATA_DIR=./data

# LLM: ollama (local) or gemini (Google AI Studio API key)
# LLM_PROVIDER=ollama
# The dashboard can override this without editing .env; the choice is stored in DATA_DIR/app_preferences.json

# --- Google Gemini (when LLM_PROVIDER=gemini) ---
# GOOGLE_API_KEY=
# GEMINI_CHAT_MODEL=gemini-2.5-flash
# GEMINI_EMBED_MODEL=gemini-embedding-001
# GEMINI_TIMEOUT_S=120
# GEMINI_EMBED_TIMEOUT_S=60

# --- Ollama (default; local) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Must match an exact name from `ollama list` (tags differ: qwen2.5:3b-instruct vs qwen2.5:3b)
OLLAMA_MODEL=qwen2.5:3b-instruct
# Embeddings for learning org facts without duplicating similar items (ollama pull nomic-embed-text)
# OLLAMA_EMBED_MODEL=nomic-embed-text
# LEARN_ORG_EMBED_ENABLED=true
# LEARN_ORG_SEMANTIC_SIMILARITY=0.78
OLLAMA_TIMEOUT_S=600
# Max chunks from the application PDF/web merged into answer drafting retrieval (default 96)
# GRANT_RETRIEVAL_CHUNK_CAP=96
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
MAX_UPLOAD_MB=50

# Read-only developer credits (Settings page — not editable in the app)
# GRANTFILLER_DEV_DISPLAY_NAME=
# GRANTFILLER_DEV_GITHUB_URL=
# GRANTFILLER_DEV_LINKEDIN_URL=
# GRANTFILLER_DEV_SPONSOR_TEXT=
# GRANTFILLER_DEV_SPONSOR_URL=

# Parse: fewer / larger chunks and parallel LLM calls (defaults are usually fine)
# CHUNK_MAX_CHARS=32000
# CHUNK_OVERLAP=400
# PARSE_CHUNK_CONCURRENCY=3

# Parse from website (HTTPS fetch; defaults usually fine)
# WEB_FETCH_TIMEOUT_S=45
# WEB_FETCH_MAX_BYTES=8000000
# WEB_MIN_EXTRACTED_CHARS=200
# Ignore system proxy for fetches (recommended): WEB_FETCH_TRUST_ENV=false
# Last-resort SSL debugging only: WEB_FETCH_SSL_VERIFY=false
# --- Local sample grant website (parse-from-URL testing) ---
# 1) From repo root:  python3 scripts/serve_grant_web_fixture.py
# 2) Uncomment the next line and restart the API:
# WEB_FETCH_ALLOW_HTTP_LOCALHOST=true
# 3) In GrantFiller, set Grant URL to:  http://127.0.0.1:8765/
# Optional: change ports (must match script --port): WEB_FETCH_HTTP_LOCAL_PORTS=8765,8080,3000
WEB_FETCH_HTTP_LOCAL_PORTS=8765,8080,3000
# JS-heavy pages: after static fetch, use headless Chromium if text is still short (requires: playwright install chromium)
# WEB_FETCH_PLAYWRIGHT=true
# WEB_FETCH_PLAYWRIGHT_TIMEOUT_MS=45000
# WEB_FETCH_PLAYWRIGHT_POST_LOAD_MS=2000

# Optional: override SQLite URL (default is DATA_DIR/grantfiller.db)
# DATABASE_URL=sqlite+aiosqlite:////absolute/path/to/grantfiller.db
