# Copy to backend/.env or set in the shell

DATA_DIR=./data
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Must match an exact name from `ollama list` (tags differ: qwen2.5:7b-instruct vs qwen2.5:7b)
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_TIMEOUT_S=600
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
MAX_UPLOAD_MB=50

# Parse: fewer / larger chunks and parallel LLM calls (defaults are usually fine)
# CHUNK_MAX_CHARS=32000
# CHUNK_OVERLAP=400
# PARSE_CHUNK_CONCURRENCY=3

# Parse from website (HTTPS fetch; defaults usually fine)
# WEB_FETCH_TIMEOUT_S=45
# WEB_FETCH_MAX_BYTES=8000000
# WEB_MIN_EXTRACTED_CHARS=200
# Ignore system proxy for fetches (recommended): WEB_FETCH_TRUST_ENV=false
# Last-resort SSL debugging only: WEB_FETCH_SSL_VERIFY=false
# Dev only: allow http://127.0.0.1 for URL import — WEB_FETCH_ALLOW_HTTP_LOCALHOST=true
# WEB_FETCH_HTTP_LOCAL_PORTS=8765,8080,3000
# JS-heavy pages: after static fetch, use headless Chromium if text is still short (requires: playwright install chromium)
# WEB_FETCH_PLAYWRIGHT=true
# WEB_FETCH_PLAYWRIGHT_TIMEOUT_MS=45000
# WEB_FETCH_PLAYWRIGHT_POST_LOAD_MS=2000

# Optional: override SQLite URL (default is DATA_DIR/grantfiller.db)
# DATABASE_URL=sqlite+aiosqlite:////absolute/path/to/grantfiller.db
